        "jsCode": "let raw = $json.output;\n\n// Se por algum motivo já vier como objeto, apenas retorna\nif (typeof raw !== 'string') {\n  return {\n    json: raw\n  };\n}\n\n// Remove ```json e ```\nraw = raw\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/i, '')\n  .trim();\n\nconst parsed = JSON.parse(raw);\n\nreturn {\n  json: parsed\n};"
