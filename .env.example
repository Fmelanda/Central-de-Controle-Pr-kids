PORT=3000
HOST=0.0.0.0
NODE_ENV=production
APP_URL=http://localhost:3001
TRUST_PROXY=false
COOKIE_SECURE=false

DASHBOARD_USER=admin
DASHBOARD_PASSWORD=troque-esta-senha
SESSION_SECRET=troque-por-uma-chave-longa-e-aleatoria
INTEGRATION_KEY=troque-por-outra-chave-longa-e-aleatoria

EVOLUTION_API_URL=http://evolution_api:8080
# Usado pelo compose.yaml para falar com a Evolution dentro da rede Docker.
EVOLUTION_API_URL_INTERNAL=http://evolution_api:8080
EVOLUTION_API_KEY=
EVOLUTION_DEFAULT_INSTANCE=

# Tamanho máximo do JSON recebido pela integração. Útil para mídia em base64.
MAX_BODY_BYTES=15728640
MAX_MEDIA_BYTES=8388608
MAX_TEXT_LENGTH=4000
LOGIN_RATE_LIMIT=10
INTEGRATION_RATE_LIMIT=600
EVOLUTION_TIMEOUT_MS=15000
